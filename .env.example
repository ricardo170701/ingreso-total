APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Zona horaria para registrar y mostrar la hora de los accesos/ingresos (por defecto America/Bogota).
# APP_TIMEZONE=America/Bogota

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="Gobernación del Meta"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Puertas / Raspberry (API de emergencia y toggle). Para pruebas sin Raspberry usar scripts/mock_door_server.py
DOOR_API_KEY=cambia_esto_por_una_clave_secreta
DOOR_EMERGENCY_PORT=8000

# OpenAI (bitácora UPS — visión). Sin clave, el análisis por imagen fallará.
OPENAI_API_KEY=
# Subir si hay timeout con varias fotos o detail=high (segundos)
OPENAI_REQUEST_TIMEOUT=90

# Bitácora UPS: modelo multimodal (gpt-4o-mini | gpt-4o | gpt-4.1). Ver tabla de costos en config/openai.php
UPS_BITACORA_AI_ENABLED=true
UPS_BITACORA_OPENAI_MODEL=gpt-4o
# auto | low | high — high recomendado para LCD/tablas A-B-C (más tokens de entrada)
UPS_BITACORA_OPENAI_IMAGE_DETAIL=high
UPS_BITACORA_OPENAI_MAX_OUTPUT_TOKENS=2000
# true = response_format json_object (más estable; desactivar si el modelo da error)
UPS_BITACORA_OPENAI_JSON_OBJECT=true
# Tolerancia al comparar formulario vs datos inferidos (0 = omitir comparación)
UPS_BITACORA_COMPARE_TOLERANCE_PCT=8
